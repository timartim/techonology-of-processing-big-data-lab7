{
  "server": {
    "host": "0.0.0.0",
    "port": 8090
  },
  "spark": {
    "app_name": "OpenFoodFacts-DataMart",
    "master": "local[2]",
    "driver_memory": "1g",
    "driver_cores": "1",
    "executor_memory": "1g",
    "executor_cores": "1",
    "memory_overhead": "256m",
    "max_result_size": "256m",
    "default_parallelism": "4",
    "shuffle_partitions": "4",
    "adaptive_enabled": "true",
    "log_level": "WARN"
  },
  "mongo": {
    "uri": "mongodb://mongo:27017/openfoodfacts",
    "database": "openfoodfacts"
  }
}
